---
import company from '../data/company.json';

interface Props {
  label?: string;
}

const { label = 'Clients & partners' } = Astro.props;

// Duplicate list for seamless loop
const partners = company.partners;
---

<section class="partner-strip rv" aria-label={label}>
  <div class="partner-strip__inner container">
    <p class="partner-strip__label">{label}</p>
  </div>
  <div class="partner-marquee" aria-hidden="false">
    <div class="partner-marquee__track">
      {[...partners, ...partners].map((partner) => (
        <div class="partner-marquee__item">
          {partner.logo
            ? <img src={partner.logo} alt={partner.name} width="120" height="48" loading="lazy" decoding="async" />
            : <span class="partner-marquee__text">{partner.name}</span>
          }
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .partner-strip {
    padding-top: clamp(1.75rem, 4vw, 2.5rem);
    padding-bottom: clamp(1.75rem, 4vw, 2.5rem);
    background: var(--warm-paper);
    border-block: 1px solid var(--border-subtle);
    overflow: hidden;
  }

  .partner-strip__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
  }

  .partner-strip__label {
    font-size: max(0.75rem, var(--text-micro));
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--stone-muted);
    margin-bottom: 1.25rem;
    text-align: center;
  }

  /* ── Marquee track ── */
  .partner-marquee {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  .partner-marquee__track {
    display: flex;
    align-items: center;
    gap: 3rem;
    width: max-content;
    animation: marquee-scroll 40s linear infinite;
  }

  .partner-marquee__track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .partner-marquee__item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0.5rem 1.5rem;
  }

  .partner-marquee__item img {
    height: 60px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
    filter: grayscale(0);
    opacity: 0.85;
    transition: opacity 0.3s;
  }

  .partner-marquee__item:hover img {
    opacity: 1;
  }

  .partner-marquee__text {
    font-family: var(--font-sans);
    font-size: clamp(0.72rem, 1.5vw, 0.82rem);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--stone);
    opacity: 0.65;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .partner-marquee__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }
  }
</style>
