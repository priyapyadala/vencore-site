---
import { buildSrcSet, preloadSrc, IMAGE_WIDTHS } from '../lib/images';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  decoding?: 'async' | 'sync' | 'auto';
  decorative?: boolean;
}

const {
  src,
  alt,
  width = 1200,
  height = 800,
  sizes = '(max-width: 767px) 100vw, (max-width: 1200px) 90vw, 1200px',
  loading = 'lazy',
  fetchpriority,
  class: className = '',
  decoding = 'async',
  decorative = false,
} = Astro.props;

const srcset = buildSrcSet(src, IMAGE_WIDTHS);
const fallbackSrc = loading === 'eager' || fetchpriority === 'high'
  ? preloadSrc(src, 768)
  : preloadSrc(src, 480);
---

<img
  src={fallbackSrc}
  srcset={srcset}
  sizes={sizes}
  alt={decorative ? '' : alt}
  width={width}
  height={height}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchpriority}
  class={className}
  aria-hidden={decorative ? 'true' : undefined}
/>
