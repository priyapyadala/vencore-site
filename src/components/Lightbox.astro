<div
  id="lightbox"
  class="lightbox"
  hidden
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Image gallery"
>
  <div class="lightbox-backdrop" data-lightbox-close tabindex="-1"></div>
  <div class="lightbox-stage">
    <button type="button" class="lightbox-close" data-lightbox-close aria-label="Close gallery">
      <span aria-hidden="true">×</span>
    </button>
    <button type="button" class="lightbox-nav lightbox-prev" aria-label="Previous image">
      <span aria-hidden="true">‹</span>
    </button>
    <figure class="lightbox-figure">
      <img class="lightbox-img" src="" alt="" decoding="async" />
      <figcaption class="lightbox-caption"></figcaption>
    </figure>
    <button type="button" class="lightbox-nav lightbox-next" aria-label="Next image">
      <span aria-hidden="true">›</span>
    </button>
    <div class="lightbox-counter" aria-live="polite"></div>
  </div>
</div>
