---
import Loader from '../components/Loader.astro';
import Lightbox from '../components/Lightbox.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
import { buildSrcSet, preloadSrc } from '../lib/images';
import '../styles/base.css';
import '../styles/colors.css';
import '../styles/layout.css';
import '../styles/components.css';
import '../styles/typography.css';
import '../styles/mega-menu.css';
import '../styles/hero.css';

interface Props {
  title: string;
  description?: string;
  current?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  noindex?: boolean;
  preloadImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Vencore Design Co., Hyderabad — Design-led execution across architecture, interiors, and turnkey project delivery.',
  current = '',
  ogImage = '/images/logo.png',
  ogType = 'website',
  articlePublishedTime,
  noindex = false,
  preloadImage,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('Vencore') ? title : `${title} — Vencore Design Co.`;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Vencore Design Co.',
  url: 'https://vencoredesign.co',
  telephone: '+91-9866014664',
  email: 'info@vencoredesign.com',
  foundingDate: '2003',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Vencore Design LLP, Door No: 9-24/9B/2, 9th Floor, Vaishnavi Cymbol, Financial District, Nanakramguda',
    addressLocality: 'Hyderabad',
    addressRegion: 'Telangana',
    postalCode: '500032',
    addressCountry: 'IN',
  },
  areaServed: 'Hyderabad',
  priceRange: '$$$$',
  description,
  image: new URL(ogImage, Astro.site).href,
};

const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdBlocks = [organizationLd, ...extraLd];
---

<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#12100e" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  {preloadImage && (
    <>
      <link
        rel="preload"
        as="image"
        href={preloadSrc(preloadImage, 480)}
        imagesrcset={buildSrcSet(preloadImage)}
        imagesizes="100vw"
        media="(max-width: 767px)"
        fetchpriority="high"
      />
      <link
        rel="preload"
        as="image"
        href={preloadSrc(preloadImage, 768)}
        imagesrcset={buildSrcSet(preloadImage)}
        imagesizes="100vw"
        media="(min-width: 768px)"
        fetchpriority="high"
      />
    </>
  )}
  <link rel="preload" href="/fonts/cormorant-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-latin-400-italic.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/outfit-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="canonical" href={canonical} />
  <meta property="og:site_name" content="Vencore Design Co." />
  <meta property="og:locale" content="en_IN" />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  {ogType === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
  )}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
  {jsonLdBlocks.map((block) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}
  {gaId && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){window.dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', gaId, { anonymize_ip: true });
      </script>
    </>
  )}
</head>
<body data-page={current}>
  <div id="scroll-progress" aria-hidden="true"></div>
  <div id="cursor-dot" aria-hidden="true"></div>
  <a class="skip-link" href="#main">Skip to content</a>
  <Loader />
  <Nav current={current} />
  <main id="main">
    <slot />
  </main>
  <Footer />
  <Lightbox />

  <a
    class="wa-float"
    href={site.social.whatsapp}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Chat with us on WhatsApp"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="28" height="28"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.528 5.867L0 24l6.335-1.662A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.006-1.37l-.36-.214-3.756.986 1.002-3.648-.234-.375A9.818 9.818 0 1 1 12 21.818z"/></svg>
    <span class="wa-float__pulse" aria-hidden="true"></span>
  </a>

  <script>
    import '../scripts/site.ts';
  </script>
</body>
</html>
