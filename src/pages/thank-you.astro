---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Thank You — Vencore Design Co."
  description="Your briefing has been received. Our team will respond within two business days."
  noindex={true}
  current="contact"
>
  <PageHero
    variant="pg-hero--contact"
    title="Briefing <em>received</em>"
    intro="Thank you — we review every enquiry with care."
    crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Thank you' },
    ]}
  />

  <section class="sec">
    <div class="container thank-you-body rv">
      <p class="prose-muted">Our team will respond within <strong>two business days</strong> with a consultation invite, site visit, or scope questions.</p>
      <p class="prose-muted">For urgent programmes, reach us on <a href="mailto:hello@vencoredesign.co">hello@vencoredesign.co</a> or <a href="tel:+919866014663" style="white-space:nowrap">+91 98660 14663</a>.</p>
      <div class="thank-you-actions">
        <a href="/projects" class="btn-ghost">View our work</a>
        <a href="/" class="btn-solid">Return home ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thank-you-body {
    max-width: 36rem;
    text-align: center;
    margin-inline: auto;
  }
  .thank-you-body .prose-muted {
    margin-inline: auto;
    margin-bottom: 1rem;
  }
  .thank-you-body a {
    color: var(--cognac);
  }
  .thank-you-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }
</style>
