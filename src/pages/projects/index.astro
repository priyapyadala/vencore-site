---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTABand from '../../components/CTABand.astro';
import ProgrammeBand from '../../components/ProgrammeBand.astro';
import ResponsiveImage from '../../components/ResponsiveImage.astro';
import { titleCase } from '../../lib/format';
import { getProjects } from '../../lib/content';

const projects = getProjects();
const filters = [
  { id: 'all', label: 'All' },
  { id: 'residential', label: 'Residential' },
  { id: 'commercial', label: 'Commercial' },
  { id: 'hospitality', label: 'Hospitality' },
  { id: 'retail', label: 'Retail' },
  { id: 'healthcare', label: 'Healthcare' },
];
---

<BaseLayout
  title="Projects — Vencore Design Co."
  description="Selected portfolio and case studies — interior fit-outs and turnkey execution across Hyderabad."
  current="projects"
  ogImage="/images/hero/projects-hero.jpeg"
  preloadImage="/images/hero/projects-hero.jpeg"
>
  <PageHero
    variant="pg-hero--projects"
    title="Selected <em>Work</em>"
    intro="Ongoing and recently completed programmes across Hyderabad, plus selected case studies."
    bgImage="/images/hero/projects-hero.jpeg"
    crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Projects' },
    ]}
  />

  <ProgrammeBand />

  <section class="sec" id="case-studies">
    <div class="container">
      <div class="s2-head rv">
        <div>
          <div class="lbl">Case Studies</div>
          <h2 class="sh2">Featured <em>programmes</em></h2>
        </div>
        <p class="s2-sub">Illustrative project pages across residential, corporate, hospitality, retail, and healthcare typologies.</p>
      </div>
      <div class="proj-filters-wrap rv">
        <div class="proj-filters" role="group" aria-label="Filter projects by category">
          {filters.map((f, i) => (
            <button
              type="button"
              class={`proj-filter-btn${i === 0 ? ' active' : ''}`}
              data-filter={f.id}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >{f.label}</button>
          ))}
        </div>
        <p id="proj-filter-count" class="proj-filter-count" aria-live="polite"></p>
      </div>
      <p id="proj-filter-empty" class="proj-filter-empty" hidden>No projects in this category yet.</p>
      <div class="pg2 rv">
        {projects.map((proj) => (
          <div class="proj-card-link proj-card-link--soon" data-project-category={proj.category}>
            <div class="pc2 pc2--soon">
              <div class="pc2-bar"></div>
              <ResponsiveImage src={proj.heroImage} alt={proj.title} sizes="(max-width:767px) 100vw, 33vw" width={1200} height={800} />
              <div class="pc2-veil"></div>
              <span class="pc2-soon" aria-hidden="true">Coming soon</span>
              <div class="pc2-info">
                <div class="pc2-cat">{titleCase(proj.category)}</div>
                <div class="pc2-name">{proj.title}</div>
                <div class="pc2-loc">{proj.location} · {proj.year}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand title="Start a programme like <em>these</em>" body="Share your typology and site — we respond with a consultation or site visit." />
</BaseLayout>

<style>
  .proj-filters-wrap { margin-bottom: 1.5rem; }
  .proj-filters {
    display: flex; flex-wrap: nowrap; gap: 0.5rem;
    overflow-x: auto; padding-bottom: 0.35rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .proj-filters::-webkit-scrollbar { display: none; }
  .proj-filter-btn {
    flex: 0 0 auto;
    padding: 0.65rem 1.1rem; min-height: 44px;
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    line-height: var(--leading-label);
    text-transform: uppercase; background: transparent; border: 1px solid var(--border-neutral);
    border-radius: 999px; cursor: pointer; color: var(--stone-muted); transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .proj-filter-btn.active, .proj-filter-btn:hover {
    background: var(--charcoal); color: var(--ivory); border-color: var(--charcoal);
  }
  .proj-filter-count {
    margin: 0.75rem 0 0;
    font-size: var(--text-small);
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .proj-filter-empty {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--muted);
    font-size: var(--text-body);
  }
  @media (min-width: 1024px) {
    .proj-filters { flex-wrap: wrap; overflow-x: visible; }
  }
</style>
